create database LibraryManagementSystem;
USE LibraryManagementSystem;
CREATE TABLE Book
(
    BookID INT PRIMARY KEY,
    Title VARCHAR(100),
    Category VARCHAR(50),
    Price DECIMAL(10,2)
);
