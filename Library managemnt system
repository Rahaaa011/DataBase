SELECT *
FROM Book
WHERE Category IN ('Computer','Science');

SELECT *
FROM Student
WHERE City != 'Abbottabad';

SELECT *
FROM Book
ORDER BY Price DESC;

SELECT *
FROM Book
LIMIT 3;

SELECT Category,
COUNT(*) AS TotalBooks
FROM Book
GROUP BY Category;

SELECT Department,
COUNT(*) AS TotalStudents
FROM Student
GROUP BY Department
HAVING COUNT(*) > 1;

SELECT *
FROM ComputerBooks;

SELECT Student.StudentName,
Book.Title
FROM Student
INNER JOIN IssueBook
ON Student.StudentID=IssueBook.StudentID

INNER JOIN Book
ON Book.BookID=IssueBook.BookID;


SELECT Student.StudentName,
Book.Title
FROM Student

LEFT JOIN IssueBook
ON Student.StudentID=IssueBook.StudentID

LEFT JOIN Book
ON Book.BookID=IssueBook.BookID;
SELECT
S1.StudentName AS Student,
S2.StudentName AS Supervisor

FROM Student S1

LEFT JOIN Student S2
ON S1.SupervisorID=S2.StudentID;

SELECT StudentName
FROM Student

WHERE StudentID IN
(
SELECT StudentID
FROM IssueBook
);


SELECT Title
FROM Book

WHERE BookID NOT IN
(
SELECT BookID
FROM IssueBook
);

SELECT StudentName
FROM Student S
WHERE EXISTS
(
SELECT *

FROM IssueBook I

WHERE S.StudentID=I.StudentID
);

SELECT
Title,
Price,

CASE
WHEN Price>1000 THEN 'Expensive'
ELSE 'Cheap'
END AS PriceStatus
FROM Book;

DELIMITER $$

CREATE TRIGGER AfterBookUpdate

AFTER UPDATE

ON Book

FOR EACH ROW
BEGIN
INSERT INTO BookLog
VALUES
(
OLD.BookID,
OLD.Title,
NOW()
);
END$$
DELIMITER ;
CREATE TABLE BookLog
(
BookID INT,
Title VARCHAR(100),
UpdatedOn DATETIME
);

