CREATE TABLE IssueBook
(
    IssueID INT PRIMARY KEY,
    StudentID INT,
    BookID INT,
    IssueDate DATE,
    FOREIGN KEY(StudentID)
    REFERENCES Student(StudentID),
    FOREIGN KEY(BookID)
    REFERENCES Book(BookID)
);



